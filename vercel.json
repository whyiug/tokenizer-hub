{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "includeFiles": "backend/tokenizers/**",
      "excludeFiles": "{.git/**,.next/**,.vercel/**,node_modules/**,backend/.venv/**,docs/**,scripts/**,src/**,coverage/**,*.md,*.ts,*.mjs,pnpm-lock.yaml,package.json,postcss.config.mjs,eslint.config.mjs,tsconfig.json,next-env.d.ts}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    }
  ]
}
